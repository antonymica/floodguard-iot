{
  "uid": "floodguard-iot",
  "title": "FloodGuard IoT - Detection Inondation",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "tags": ["iot", "mqtt", "floodguard"],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Niveau d'eau",
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb-floodguard"
      },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"floodguard\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"floodguard\")\n  |> filter(fn: (r) => r._field == \"water_level\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"water_level\")"
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 16,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1300
              },
              {
                "color": "red",
                "value": 2700
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Dernier niveau d'eau",
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb-floodguard"
      },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"floodguard\")\n  |> range(start: -30m)\n  |> filter(fn: (r) => r._measurement == \"floodguard\")\n  |> filter(fn: (r) => r._field == \"water_level\")\n  |> last()"
        }
      ],
      "gridPos": {
        "h": 9,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1300
              },
              {
                "color": "red",
                "value": 2700
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": ["lastNotNull"],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Alerte inondation",
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb-floodguard"
      },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"floodguard\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"floodguard\")\n  |> filter(fn: (r) => r._field == \"alert_value\")\n  |> aggregateWindow(every: v.windowPeriod, fn: max, createEmpty: false)\n  |> yield(name: \"alert_value\")"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 9
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Etat du capteur",
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb-floodguard"
      },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"floodguard\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"floodguard\")\n  |> filter(fn: (r) => r._field == \"status_code\")\n  |> aggregateWindow(every: v.windowPeriod, fn: max, createEmpty: false)\n  |> yield(name: \"status_code\")"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 9
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "min": 0,
          "max": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 2
              }
            ]
          }
        },
        "overrides": []
      }
    }
  ],
  "time": {
    "from": "now-15m",
    "to": "now"
  }
}
