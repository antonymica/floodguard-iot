      "title": "État du risque",
      "datasource": {
        "type": "influxdb",
        "uid": "influxdb-floodguard"
      },
      "targets": [
        {
          "refId": "A",
          "query": "from(bucket: \"floodguard\")\n  |> range(start: -30m)\n  |> filter(fn: (r) => r._measurement == \"floodguard\")\n  |> filter(fn: (r) => r._field == \"risk_code\")\n  |> last()\n  |> map(fn: (r) => ({ r with _value: float(v: r._value) }))"
